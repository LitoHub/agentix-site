# ── Variables de la agenda (calendario) ──────────────────────────────────────
# Copia este archivo a `.env` (gitignored) para probar el MODO REAL en local,
# o pon estas mismas variables en Netlify para producción. Ver SETUP-AGENDA.md.

# Google Calendar (OAuth) — crea el evento real COMO el usuario autorizado + Meet nativo.
# El refresh token lo genera el script: node scripts/google-oauth-setup.js
GOOGLE_OAUTH_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=xxxxx
GOOGLE_OAUTH_REFRESH_TOKEN=xxxxx
GOOGLE_CALENDAR_ID=primary
# Opcional: sala fija de videollamada de respaldo
# MEETING_URL=https://meet.google.com/abc-defg-hij
#
# (Alternativa service account, si algún día no usas OAuth:)
# GOOGLE_CLIENT_EMAIL=...@...iam.gserviceaccount.com
# GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Supabase (guardar los leads) — mismas llaves del .env raíz del repo
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

# Gmail SMTP (enviar los 2 correos) — requiere "App password" (2FA activado)
GMAIL_USER=admin@parallelo.com.co
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx
# Opcional
# ADMIN_EMAIL=admin@parallelo.com.co
# EMAIL_FROM_NAME=Agentix
